# ══════════════════════════════════════════════════════════════════════════════
# AmixPay Monorepo — Root .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.iml

# ── Environment ───────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── Node (API) ────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Flutter (Mobile) ─────────────────────────────────────────────────────────
apps/mobile/build/
apps/mobile/.dart_tool/
apps/mobile/.flutter-plugins
apps/mobile/.flutter-plugins-dependencies
apps/mobile/.packages
apps/mobile/pubspec.lock
apps/mobile/**/*.g.dart
apps/mobile/**/*.freezed.dart

# Flutter build artifacts
apps/mobile/android/.gradle/
apps/mobile/android/captures/
apps/mobile/android/local.properties
apps/mobile/android/app/debug/
apps/mobile/android/app/profile/
apps/mobile/android/app/release/
apps/mobile/ios/Pods/
apps/mobile/ios/.symlinks/
apps/mobile/ios/Flutter/Flutter.framework
apps/mobile/ios/Flutter/Flutter.podspec
apps/mobile/ios/Runner/GeneratedPluginRegistrant.*

# Signing keys — NEVER commit
apps/mobile/android/*.jks
apps/mobile/android/*.keystore
apps/mobile/android/key.properties

# ── Docker ────────────────────────────────────────────────────────────────────
postgres_data/
redis_data/

# ── Backups & temp ────────────────────────────────────────────────────────────
*.bak
*.tmp
CODEBASE_ASSESSMENT.md
amixpay-api/
amixpay-app/
apps/mobile/android/app/*.jks.old
