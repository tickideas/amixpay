# ============================================================
# AmixPay API — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Server
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4200

# JWT (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=CHANGE_ME_generate_64_byte_hex
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=amixpay
DB_USER=postgres
DB_PASSWORD=postgres

# Redis
REDIS_URL=redis://localhost:6379

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Flutterwave (https://dashboard.flutterwave.com/settings/apis)
# SECRET KEY stays server-side ONLY — never put in the Flutter app
FLW_PUBLIC_KEY=FLWPUBK_TEST-...
FLW_SECRET_KEY=FLWSECK_TEST-...
FLW_ENCRYPTION_KEY=your_encryption_key
# Set this in Flutterwave dashboard → Settings → Webhooks → Secret Hash
FLW_WEBHOOK_HASH=your_webhook_secret_hash
FLW_CALLBACK_URL=https://api.amixpay.com/v1/flutterwave/webhooks

# Wise / TransferWise (https://api-docs.wise.com/)
WISE_API_KEY=your_wise_api_key
WISE_PROFILE_ID=your_wise_profile_id
WISE_API_URL=https://api.sandbox.transferwise.tech

# Plaid (https://dashboard.plaid.com/)
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox

# Open Exchange Rates (https://openexchangerates.org/signup)
OPEN_EXCHANGE_RATES_KEY=your_key_here

# Firebase / FCM Push Notifications
FIREBASE_SERVER_KEY=your_fcm_server_key

# Twilio SMS (https://www.twilio.com/console)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# useSend (self-hosted — https://usesend.com)
USESEND_URL=https://send.example.com
USESEND_API_KEY=us_your_api_key_here
EMAIL_FROM=noreply@amixpay.com

# SendGrid Email (https://app.sendgrid.com/settings/api_keys)
SENDGRID_API_KEY=SG.your_key_here
SENDGRID_FROM_EMAIL=noreply@amixpay.com

# AWS (for production)
AWS_REGION=us-east-1
AWS_S3_BUCKET=amixpay-documents
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
